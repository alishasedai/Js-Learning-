<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    
       <div class="w-full min-h-screen bg-zinc-900 p-10 text-white" >
         <a class="text-green-400 text-2xl bg-blue-500 rounded-lg px-3 py-1 " href="/">Back To Home</a>
        <h1 class="text-3xl tracking-tighter mt-6 mb-5">All Users</h1>
        <div class="users flex flex-wrap gap-5 justify-start w-full">
           <% users.forEach(user => { %>
             <div class="user w-[212px] p-4 flex-none bg-zinc-600 rounded-lg">
                <div class="w-full h-52 bg-red-700 overflow-hidden"> 
                    <img class="w-full h-full object-cover"  src="<%= user.image_url %>" alt="">
                </div>
                <h3 class="text-white text-2xl mt-2"><%= user.name %></h3>
                <h5 class="text-zinc-400"><%= user.email %></h5>
                <div class="flex gap-4 justify-between mt-4 ">
                    <a class="text-zinc-300" href="/edit/<%= user._id %>">Edit User</a>
                    <a class="text-red-500" href="/delete/<%= user._id %>">Delete User</a>
                </div>
                
            </div>
            
         <% }); %>
        </div>
</body>
</html>