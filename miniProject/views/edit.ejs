<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full bg-zinc-900 min-h-screen text-white p-10">
        <div class="ju flex justify-content gap-40">
            
        <a class="bg-red-600 px-4 mb-5 py-2 rounded-lg text-sm" href="/logout">Logout</a>
        </div>
        <div class="mt-5">
        <h5 class="mb-5 text-2xl">Edit your post.</h5>
        <form action="/update/<%= editPost._id %>" method="post">
            <textarea placeholder="what's on your mind" class="text-xl w-1/3 resize-none h-40 text-white border-2 border-zinc-700 rounded-md" name="content"><%= editPost.content %></textarea>
            <input class="bg-yellow-600 px-5 w-50 py-3 rounded-lg block mt-5" type="submit" value="Update Post">
        </form>
        </div>
      
    </div>
    
</body>
</html>