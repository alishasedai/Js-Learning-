<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full bg-zinc-900 min-h-screen text-white p-10">
        <div class="ju flex justify-content gap-40">
            <h2 class="text-2xl mb-5">Your Profile view</h2>
        <a class="bg-red-600 px-4 mb-5 py-2 rounded-lg text-sm" href="/logout">Logout</a>
        </div>
        <div class="mt-5">
            <h3>Hello,  <%= data.name %> 👋</h3>
        <h5 class="mb-5 text-2xl">You can create a new post.</h5>
        <form action="/post" method="post">
            <textarea placeholder="what's on your mind" class="text-xl w-1/3 resize-none h-40 text-white border-2 border-zinc-700 rounded-md" name="content"></textarea>
            <input class="bg-blue-600 px-5 w-50 py-3 rounded-lg block mt-5" type="submit" value="Create New Post">
        </form>
        </div>
       <div class="posts mt-6">
    <h2 class="text-3xl text-zinc-300">Your posts</h2>

   

    <div class="postContainer mt-4">
         <% data.post.forEach(function(post){ %>
        <div class="w-140 rounded-lg mb-5 p-5 bg-zinc-800 border-2 border-zinc-700">

            <h2 class="text-blue-400 mb-3">@<%= post._id %></h2>
            <p class="text-sm tracking-tight"><%= post.content %></p>
            <small mb-2><%= post.likes.length%> likes</small>
            <div class="btn flex justify-content gap-20 mt-2">
                <a class="text-blue-500" href="/like/<%= post._id %>">Like</a>
                <a class="text-zinc-500" href="/edit">Edit</a>
            </div>

        </div>
            <% }) %>
    </div>


</div>
    </div>
    
</body>
</html>