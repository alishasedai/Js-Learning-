<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full bg-zinc-900 min-h-screen text-white p-10">
        <h2 class="text-3xl mb-5">Login in your account</h2>
        <form action="/login" method="post">
           
            <input class="px-4 py-3 outline-none bg-transparent border-2 border-zinc-700 mr-6 rounded-lg" type="email" placeholder="email" name="email">
           
            <input class="px-4 py-3 outline-none bg-transparent border-2 border-zinc-700 mr-6 rounded-lg" type="password" placeholder="password" name="password">
            
            <input class="px-4 py-2 bg-blue-600 rounded-lg mt-5" type="submit" value="Login Account">
        </form>
    </div>
    
</body>
</html>